using System;
using System.Threading;

namespace Level14_The_Umbra;

public static class UmbraFight
{
    public static void Main()
    {
        /*NOTES*/
        //rounds = 1 - 100
        //umbraDistance = 25 - 75
        //structures = 20
        //siegeEngine range = 0 - 100

        /*VARIABLES*/
        int structures = 20;
        int round = 1;
        int umbraHp = 20;
        int umbraDistance = Random.Shared.Next(25, 75);

        /*ROUND-LOOP START*/
        while (round <= 100)
        {
            int umbraSpeed = Random.Shared.Next(1, 3);
            umbraDistance = umbraDistance - Random.Shared.Next(1, 3);

            int engineDmg = 1 * UmbraFight.critMethod(round);
            int engineRange;

            /*DISPLAY*/
            Console.Clear();
            Console.ForegroundColor = ConsoleColor.Yellow;
            Console.WriteLine("\nBOSS BATTLE: THE UMBRA\n\n");
            Console.ResetColor();
            Console.WriteLine("The Umbra approaches,\nready the Siege Engine and destroy it at all cost!\n");

            /*Raw-String Panel*/
            Console.WriteLine($"""
                     
                     ========== ROUND: {round} =========

                       Structure Damage: {structures} / 20
                          Umbra Health: {umbraHp} / 20
                          
                     =============================
                              
                
            """);

            /*BATTLE SCREEN*/
            Console.Write("Enter Distance (0-100): ");
            engineRange = Convert.ToInt32(Console.ReadLine());

            /* == */
            if (engineRange == umbraDistance)
            {
                Console.WriteLine("\nDIRECT HIT!");
                umbraHp = umbraHp - engineDmg;

                /*CritMessage Switch*/
                string critStrenght = engineDmg switch
                {
                    5 => "***HEAVY CRIT***",
                    3 => "***CRIT***",
                    _ => ""
                };
                Console.WriteLine(critStrenght);
            }

            /* > */
            else if (engineRange != umbraDistance && engineRange > umbraDistance)
            {
                Console.WriteLine("\nThat went too far!");
                structures = structures - 1;
            }

            /* < */
            else if (engineRange != umbraDistance && engineRange < umbraDistance)
            {
                Console.WriteLine("\nNot far enough!");
                structures = structures - 1;
            }

            /*WIN-GAMEOVER MESSAGES*/
            if (umbraDistance <= 0)
            {
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine("\nYou were stomped by the Umbra!\nGAMEOVER!");
                Console.ResetColor();
                break;
            }
            if (structures <= 0)
            {
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine("\nOh No! The Umbra has ravaged the whole city!\nGAMEOVER!");
                Console.ResetColor();
                break;
            }
            if (umbraHp <= 0)
            {
                Console.ForegroundColor = ConsoleColor.Green;
                Console.WriteLine("\nTHE UMBRA HAS BEEN KILLED!!!");
                Console.ResetColor();
                break;
            }

            Thread.Sleep(3000);
            round++;
        }
    }

    /*CRIT METHOD*/
    public static int critMethod(int round)
    {
        if (round % 3 == 0 && round % 5 == 0)
        {
            return 5;
        }
        else if (round % 3 == 0 || round % 5 == 0)
        {
            return 3;
        }
        else return 1;
    }

}
